# AI Model API Keys
# At least one model must be configured

# Anthropic Claude (claude-sonnet-4-20250514)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT-4o
OPENAI_API_KEY=your_openai_api_key_here

# DeepSeek (supports function calling, works with Agent mode)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Gemini via OpenAI-compatible gateway (grsai)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://grsai.dakka.com.cn/v1
GEMINI_MODEL=gemini-3.1-pro

# JWT Secret for authentication (generate a random string for production)
JWT_SECRET=change-me-to-a-random-secret

# Database (auto-configured in Docker, only needed for local dev)
# DATABASE_URL=postgresql://atoms:atoms_dev_password@localhost:5432/atoms

# E2B Sandbox (optional - enables real code execution in Agent mode)
# Sign up at https://e2b.dev to get your API key
# E2B_API_KEY=e2b_***

# Neon Database (optional - enables auto database provisioning in Agent mode)
# Sign up at https://neon.tech to get your API key
# NEON_API_KEY=your_neon_api_key_here

# Supabase (optional - falls back to anonymous mode)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
